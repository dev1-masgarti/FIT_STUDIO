# Server-side only — for Edge Functions, migrations, admin scripts
# Copy to .env.local — NEVER commit .env.local or use in mobile app

SUPABASE_URL=https://spcnvkgzzmtdzehrarnp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key_here

# For ./scripts/apply-migrations.sh (Settings → Database → connection string)
# URL-encode special characters in the password (e.g. ? → %3F)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.spcnvkgzzmtdzehrarnp.supabase.co:5432/postgres

# POE image generation (server-side only)
POE_API_KEY=sk-poe_your_key_here
POE_API_URL=https://api.poe.com/v1/chat/completions
POE_IMAGE_MODEL=GPT-Image-1

# Cloudinary unsigned upload (server-side only)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UNSIGNED_PRESET=fit-studio
