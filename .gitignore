
node_modules/
.DS_Store

# Legacy file-based backend store (replaced by Postgres)
apps/backend/data/

# Local-only env files — never committed in plaintext
.env
.env.local
.env.*.local
**/.env
**/.env.local
# Exception: supabase/.env is git-crypt encrypted (see .gitattributes)
!supabase/.env

# git-crypt key — NEVER commit the key itself
*.git-crypt-key
git-crypt-key

# NOTE: credential files under **/credentials/ and client_secret_*.json ARE
# committed, but ENCRYPTED via git-crypt (see .gitattributes). They are
# intentionally NOT ignored so the encrypted blobs can be versioned & shared.
