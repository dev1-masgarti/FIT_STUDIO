
node_modules/
.DS_Store

# Local-only env files — never committed (not even encrypted)
.env
.env.local
.env.*.local

# git-crypt key — NEVER commit the key itself
*.git-crypt-key
git-crypt-key

# NOTE: credential files under **/credentials/ and client_secret_*.json ARE
# committed, but ENCRYPTED via git-crypt (see .gitattributes). They are
# intentionally NOT ignored so the encrypted blobs can be versioned & shared.
